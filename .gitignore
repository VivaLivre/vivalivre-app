# ==================================================
# VivaLivre App — .gitignore (Flutter)
# ==================================================

# ──────────────────────────────────────────────────
# Miscelânea
# ──────────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ──────────────────────────────────────────────────
# IDEs
# ──────────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/
# .vscode/ — manter comentado se quiser versionar configs do VS Code

# ──────────────────────────────────────────────────
# Flutter / Dart / Pub
# ──────────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Código gerado automaticamente
**/*.g.dart
**/*.freezed.dart
lib/generated_plugin_registrant.dart

# Symbolication & Obfuscation
app.*.symbols
app.*.map.json

# ==================================================
# 🚨 SEGURANÇA — Nunca commitar estas chaves!
# ==================================================

# Firebase — configurações com chaves privadas
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# Keystore de assinatura Android
android/key.properties
*.jks
*.keystore

# Variáveis de ambiente
.env
.env.*
!.env.example

# ==================================================
# Android (artefatos de build nativo)
# ==================================================
android/.gradle/
android/app/build/
android/app/debug/
android/app/profile/
android/app/release/
android/local.properties
android/captures/

# ==================================================
# iOS (artefatos de build nativo)
# ==================================================
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.podspec
ios/build/
ios/DerivedData/

# Documentação VivaLivre
AGENTS.md
